#!/bin/bash
# AIda CLI wrapper — sets up environment and runs the CLI
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
export PYTHONPATH="$SCRIPT_DIR/src"

# Load API key
if [ -f /home/henric/generalassistant/.env ]; then
    eval "$(grep '^ANTHROPIC_API_KEY=' /home/henric/generalassistant/.env)"
    export ANTHROPIC_API_KEY
fi

exec /home/henric/generalassistant/.venv/bin/python -m aida.cli "$@"
